{
  "info": {
    "name": "UTI - API Completa",
    "_postman_id": "uti-full-api-v1",
    "description": "Coleccion completa de todos los endpoints del backend UTI Bunna.\nCubre: Auth, Users, Drivers (SQL Matches), Matches (MongoDB).\nCorrer primero la carpeta 'Auth' para obtener los tokens de driver y passenger.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "driverToken",
      "value": "",
      "type": "string",
      "description": "Token JWT del conductor. Se llena al correr 'Login como Driver'"
    },
    {
      "key": "passengerToken",
      "value": "",
      "type": "string",
      "description": "Token JWT del pasajero. Se llena al correr 'Login como Passenger'"
    },
    {
      "key": "passengerId",
      "value": "",
      "type": "string",
      "description": "ID del pasajero. Completar manualmente o extraer de la DB"
    }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register - Driver",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 - Driver registrado', () => pm.response.to.have.status(201));",
                  "pm.test('Retorna token', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('token');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Carlos Driver\",\n  \"email\": \"driver@ejemplo.com\",\n  \"password\": \"clave123\",\n  \"role\": \"driver\",\n  \"shift\": \"morning\",\n  \"phone\": \"3001234567\",\n  \"address\": \"Calle 50 #30-10\",\n  \"location\": {\n    \"type\": \"Point\",\n    \"coordinates\": [-75.59, 6.25]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Register - Passenger",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 - Passenger registrado', () => pm.response.to.have.status(201));",
                  "pm.test('Retorna token', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('token');",
                  "  const userId = json.user && json.user.user_id;",
                  "  if (userId) pm.collectionVariables.set('passengerId', String(userId));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ana Passenger\",\n  \"email\": \"passenger@ejemplo.com\",\n  \"password\": \"clave123\",\n  \"role\": \"passenger\",\n  \"shift\": \"morning\",\n  \"phone\": \"3109876543\",\n  \"address\": \"Carrera 80 #45-20\",\n  \"location\": {\n    \"type\": \"Point\",\n    \"coordinates\": [-75.60, 6.23]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login como Driver",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('driverToken', json.token);",
                  "  pm.test('driverToken guardado', () => pm.expect(json.token).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"driver@ejemplo.com\",\n  \"password\": \"clave123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login como Passenger",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('passengerToken', json.token);",
                  "  pm.test('passengerToken guardado', () => pm.expect(json.token).to.be.a('string'));",
                  "}",
                  "if (json.user && json.user.user_id) {",
                  "  pm.collectionVariables.set('passengerId', String(json.user.user_id));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"passenger@ejemplo.com\",\n  \"password\": \"clave123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Register - Email ya existente (409)",
          "event": [
