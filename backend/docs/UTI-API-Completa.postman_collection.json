    {
      "name": "2. Users - Update Profile",
      "item": [
        {
          "name": "PATCH me - Actualizar phone_number (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna user sin password_hash', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('user');",
                  "  pm.expect(json.user).to.not.have.property('password_hash');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{driverToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"3001112233\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me"]
            }
