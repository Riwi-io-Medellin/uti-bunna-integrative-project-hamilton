    {
      "name": "4. Matches - MongoDB",
      "item": [
        {
          "name": "GET /matches/me - Pasajero ve sus matches (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 404', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});",
                  "pm.test('Respuesta tiene ok y data', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('ok');",
                  "  pm.expect(json).to.have.property('data');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{passengerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/matches/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "matches", "me"]
            }
          }
        },
