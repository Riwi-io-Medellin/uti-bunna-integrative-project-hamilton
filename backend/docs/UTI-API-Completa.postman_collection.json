              "mode": "raw",
              "raw": "{\n  \"email\": \"driver@ejemplo.com\",\n  \"password\": \"claveIncorrecta\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
