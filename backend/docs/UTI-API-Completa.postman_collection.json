    {
      "name": "3. Drivers - SQL Matches",
      "item": [
        {
          "name": "GET matches - Driver obtiene pasajeros cercanos (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna driverId y matches', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('driverId');",
                  "  pm.expect(json).to.have.property('matches');",
                  "  pm.expect(json).to.have.property('total');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{driverToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/drivers/matches",
              "host": ["{{baseUrl}}"],
              "path": ["api", "drivers", "matches"]
            }
          }
        },
