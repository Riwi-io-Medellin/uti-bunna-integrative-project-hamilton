{
  "info": {
    "name": "UTI - Update Profile",
    "_postman_id": "uti-update-profile-v1",
    "description": "Colección de pruebas para el endpoint PATCH /api/users/me.\nCubre autenticación, validaciones de esquema, lógica de contraseña y actualización de teléfono.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Se llena automáticamente al correr '0. Login'"
    }
  ],
  "item": [
    {
      "name": "0. Login (obtiene token automáticamente)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.token) {",
              "  pm.collectionVariables.set('token', res.token);",
              "  pm.test('Token guardado correctamente', () => pm.expect(res.token).to.be.a('string'));",
              "} else {",
              "  pm.test('Login fallido - revisa email/password', () => pm.expect.fail(JSON.stringify(res)));",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"usuario@ejemplo.com\",\n  \"password\": \"tu_password_actual\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "1. Sin token - 401",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));",
              "pm.test('Mensaje de error correcto', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.error).to.include('token');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone_number\": \"3001234567\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "me"]
        }
      }
    },
    {
      "name": "2. Campo no permitido (address) - 400",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('Respuesta contiene errors', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('errors');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"address\": \"Calle Falsa 123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "me"]
        }
      }
    },
    {
      "name": "3. Body vacio - 400",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('Error por minProperties', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('errors');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "me"]
        }
      }
    },
    {
      "name": "4. newPassword sin currentPassword - 400",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('Mensaje indica currentPassword requerido', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.message).to.include('currentPassword');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"newPassword\": \"nuevaClave123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "me"]
        }
      }
    },
    {
      "name": "5. Contrasena actual incorrecta - 401",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));",
              "pm.test('Mensaje indica contraseña incorrecta', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.message).to.include('incorrect');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"currentPassword\": \"claveEquivocada\",\n  \"newPassword\": \"nuevaClave123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "me"]
        }
      }
    },
    {
      "name": "6. Actualizar solo phone_number - 200",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Responde con user actualizado', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('user');",
              "  pm.expect(json.user.phone).to.equal('3001234567');",
              "});",
              "pm.test('No expone password_hash', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.user).to.not.have.property('password_hash');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone_number\": \"3001234567\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "me"]
        }
      }
    },
    {
      "name": "7. Actualizar solo password - 200",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Responde con user actualizado', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('user');",
              "});",
              "pm.test('No expone password_hash', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.user).to.not.have.property('password_hash');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"currentPassword\": \"tu_password_actual\",\n  \"newPassword\": \"nuevaClave123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "me"]
        }
      }
    },
    {
      "name": "8. Actualizar phone + password juntos - 200",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Responde con user actualizado', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('user');",
              "  pm.expect(json.user.phone).to.equal('3109876543');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone_number\": \"3109876543\",\n  \"currentPassword\": \"nuevaClave123\",\n  \"newPassword\": \"otraClave456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "me"]
        }
      }
    }
  ]
}
